# ============================================
# Edel Runway Bot Configuration
# Copy this file to .env and edit as needed
# ============================================

# Voting Strategy: "random" | "smart" | "first" | "second"
#   random = pilih acak dari 2 asset
#   smart  = analisa data di halaman, pilih yang lebih populer/momentum
#   first  = selalu pilih asset pertama (kiri)
#   second = selalu pilih asset kedua (kanan)
VOTE_STRATEGY=smart

# Dynamic Scheduling
# Interval antar vote setelah sukses (menit)
VOTE_INTERVAL_MINUTES=60
# Buffer tambahan agar EDELx sempat unlock (menit)
VOTE_BUFFER_MINUTES=5
# Retry interval jika belum siap / gagal (menit)
RETRY_INTERVAL_MINUTES=5

# Browser Settings
# headless=true untuk VPS (tanpa GUI), false untuk debug
HEADLESS=true

# Slow motion delay (ms) - untuk menghindari deteksi bot
# Semakin tinggi semakin mirip manusia, tapi lebih lambat
SLOW_MO=500

# Timeout (ms) untuk menunggu halaman/element
PAGE_TIMEOUT=30000

# Retry Settings
MAX_RETRIES=3
RETRY_DELAY=5000

# Screenshot setiap vote (true/false)
SAVE_SCREENSHOTS=true

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Runway Desk URL
BASE_URL=https://runway.edel.finance

# ============================================
# Telegram Bot Notifications
# ============================================
# 1. Buat bot baru di Telegram: chat @BotFather → /newbot
# 2. Copy token yang diberikan ke TELEGRAM_BOT_TOKEN
# 3. Kirim pesan apa saja ke bot kamu
# 4. Buka: https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. Cari "chat":{"id": ... } → copy angka ID ke TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
